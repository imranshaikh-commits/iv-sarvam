# =====================================================
# SARVAM — Hermes Agent Environment Variables
# =====================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. chmod 600 .env after creation.

# ---- OpenRouter (LLM routing) ----
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_FALLBACK_1=z-ai/glm-5.2
OPENROUTER_FALLBACK_2=anthropic/claude-sonnet-4.6
OPENROUTER_ESCALATION_MODEL=anthropic/claude-sonnet-4.6

# ---- Supabase (Data + Auth + RAG) ----
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ---- Embedding model (for RAG ingestion) ----
# Using OpenAI text-embedding-3-small ($0.02/M tokens, 1536-dim)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---- Hermes Agent runtime ----
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=8643
HERMES_DATA_DIR=./hermes-data

# ---- Retrieval config ----
RETRIEVAL_MIN_SIMILARITY=0.75
RETRIEVAL_TOP_K=5

# ---- Cloudflare Worker (frontend auth proxy) ----
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FRONTEND_URL=https://sarvam.inspiritvision.com

# ---- Basic auth (interim, Sprint 4 only — remove after Sprint 8) ----
CADDY_BASIC_AUTH_USER=imran
CADDY_BASIC_AUTH_HASH=  # generate with: caddy hash-password
